{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "frontend-admin/steps",
  "title": "Form Steps",
  "description": "Groups fields and other content into steps.",
  "category": "frontend-admin",
  "textdomain": "frontend-admin",
  "icon": "list-view",
  "supports": {
    "align": [
      "wide"
    ]
  },
  "providesContext": {
    "frontend-admin/steps/active_step": "active_step"
  },
  "attributes": {
    "active_step": {
      "type": "number",
      "default": 0
    },
    "validate_steps": {
      "type": "boolean",
      "default": false
    },
    "steps_tabs_display": {
      "type": "boolean",
      "default": true
    },
    "steps_counter_display": {
      "type": "boolean",
      "default": false
    },
    "counter_text": {
      "type": "string",
      "default": "{current_step} / {total_steps}"
    },
    "tabs_align": {
      "type": "string",
      "default": "left"
    },
    "tab_links": {
      "type": "boolean",
      "default": false
    }
  },
  "editorScript": "file:../../steps/index.js"
}